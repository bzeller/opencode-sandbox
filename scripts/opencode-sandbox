#!/usr/bin/env python3
import argparse
import os
import subprocess
import sys
import hashlib
import json
import urllib.request
from datetime import datetime
from pathlib import Path

# --- PATH RESOLUTION (Symlink-Safe) ---
SCRIPT_DIR = Path(__file__).resolve().parent

# XDG Compliance with fallbacks for empty or unset variables
XDG_CONFIG_HOME = Path(os.environ.get("XDG_CONFIG_HOME") or Path.home() / ".config")
XDG_DATA_HOME = Path(os.environ.get("XDG_DATA_HOME") or Path.home() / ".local/share")

def find_template():
    """Find the Dockerfile template in known locations. XDG wins."""
    possible_paths = [
        XDG_CONFIG_HOME / "opencode-sandbox" / "Dockerfile.template",
        SCRIPT_DIR.parent / "config" / "Dockerfile.template"
    ]
    for p in possible_paths:
        if p.exists():
            return p
    return None

TEMPLATE_PATH = find_template()

def doctor_check():
    """Verify the environment is sane."""
    try:
        subprocess.run(["podman", "--version"], capture_output=True, check=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        print("❌ Error: 'podman' not found. Please install it first.")
        sys.exit(1)

    if not TEMPLATE_PATH:
        print("❌ Error: Dockerfile.template not found.")
        sys.exit(1)

def get_workspace_hash(path):
    """Generates a unique short hash based on the absolute path."""
    return hashlib.md5(str(path.resolve()).encode()).hexdigest()[:8]

def load_template():
    return TEMPLATE_PATH.read_text()

def version_tuple(v):
    """Convert version string to tuple for comparison."""
    try:
        # Split by . and only take numeric parts to avoid 'v' or '-beta' issues
        return tuple(map(int, (part for part in v.split('.') if part.isdigit())))
    except:
        return (0, 0, 0)

def get_latest_opencode_version(debug=False):
    """Fetch the latest version tag from GitHub."""
    url = "https://api.github.com/repos/anomalyco/opencode/releases/latest"
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "opencode-sandbox-cli"})
        with urllib.request.urlopen(req, timeout=5) as response:
            data = json.loads(response.read().decode())
            latest = data.get("tag_name", "").lstrip("v")
            if debug:
                print(f"DEBUG: Latest OpenCode version on GitHub: v{latest}")
            return latest
    except Exception as e:
        print(f"⚠️ Warning: Could not check for latest version: {e}")
    return None

def load_sidecar_config(work_dir, debug=False):
    sidecar = work_dir / ".opencode-sandbox.json"
    cfg = {
        "base_image": "opensuse/tumbleweed:latest",
        "install": [],
        "mounts": []
    }
    if sidecar.exists():
        try:
            with open(sidecar, 'r') as f:
                user_cfg = json.load(f)
                cfg.update(user_cfg)
            if debug:
                print(f"📦 Loaded sidecar config: {sidecar}")
        except Exception as e:
            print(f"⚠️ Warning: Failed to parse sidecar: {e}")
    return cfg

def main():
    parser = argparse.ArgumentParser(description="OpenCode Sandbox (Podman + openSUSE)")
    parser.add_argument("--rebuild", action="store_true", help="Force image rebuild")
    parser.add_argument("--dry-run", action="store_true", help="Show command without running")
    parser.add_argument("--debug", action="store_true", help="Show debug information")
    parser.add_argument("--root", action="store_true", help="Run container as root")
    parser.add_argument("--update", action="store_true", help="Check for and install OpenCode updates")
    parser.add_argument("--include-dir", action="append", help="Include additional directory in /mnt (HostPath:ContainerPath or just HostPath)")
    parser.add_argument("cmd_args", nargs=argparse.REMAINDER, help="Arguments to pass to opencode")
    args = parser.parse_args()

    # 1. Setup Workspace Paths
    work_dir = Path.cwd().resolve()
    ws_hash = get_workspace_hash(work_dir)
    
    if args.debug:
        print(f"DEBUG: work_dir={work_dir} | ws_hash={ws_hash}")
    
    # Global Config (Shared)
    xdg_config = XDG_CONFIG_HOME / "opencode-sandbox"
    # Workspace Data (Isolated)
    xdg_data = XDG_DATA_HOME / "opencode-sandbox"
    ws_meta_dir = xdg_data / f"ws-{ws_hash}"
    
    # Ensure host directories exist
    ws_meta_dir.mkdir(parents=True, exist_ok=True)
    xdg_config.mkdir(parents=True, exist_ok=True)

    # 2. Load Template & Config
    cfg = load_sidecar_config(work_dir, debug=args.debug)
    template_content = load_template()
    
    dockerfile_content = template_content.format(
        base_image=cfg.get('base_image', 'opensuse/tumbleweed:latest'),
        extra_packages=" ".join(f"'{p}'" for p in cfg.get('install', []))
    )

    if args.dry_run or args.debug:
        print(f"--- GENERATED DOCKERFILE ---\n{dockerfile_content}\n----------------------------")

    # 3. Image Versioning
    content_hash_input = dockerfile_content + json.dumps(cfg, sort_keys=True)
    content_hash = hashlib.md5(content_hash_input.encode()).hexdigest()[:8]
    image_tag = f"opencode-ws:{ws_hash}-{content_hash}"
    
    image_check = subprocess.run(["podman", "images", "-q", image_tag], capture_output=True).stdout

    if not image_check or args.rebuild:
        print(f"🔨 Building workspace image: {image_tag}")
        df_path = ws_meta_dir / "Dockerfile"
        df_path.write_text(dockerfile_content)
        try:
            subprocess.run(["podman", "build", "-t", image_tag, "-f", str(df_path), "."], check=True)
        except subprocess.CalledProcessError as e:
            print(f"❌ Error: 'podman build' failed for {image_tag}")
            sys.exit(e.returncode)

    # Check if this is the first run
    is_first_run = len(list(ws_meta_dir.iterdir())) <= 1

    # 4. Execute Sandbox
    internal_home = "/home/developer"
    podman_cmd = [
        "podman", "run", "-it", "--rm",
        "--name", f"opencode-{ws_hash}-{int(datetime.now().timestamp())}",
        "--userns=keep-id",
        "--workdir", "/workspace",
        "-v", f"{work_dir}:/workspace:Z",
        "-v", f"{xdg_config}:{internal_home}/.config/opencode:Z",
        "-v", f"{ws_meta_dir}:{internal_home}/.local/share/opencode:Z",
    ]

    # Add custom mounts
    for m in cfg.get("mounts", []):
        try:
            host_p = Path(m["host"]).expanduser().resolve()
            cont_p = m["container"]
            podman_cmd.extend(["-v", f"{host_p}:{cont_p}:Z"])
        except KeyError as e:
            print(f"⚠️ Warning: Invalid mount configuration: missing {e}")

    # Add extra directories from CLI
    if args.include_dir:
        for inc in args.include_dir:
            if ":" in inc:
                h_p, c_p = inc.split(":", 1)
                h_p = Path(h_p).expanduser().resolve()
                podman_cmd.extend(["-v", f"{h_p}:{c_p}:Z"])
            else:
                h_p = Path(inc).expanduser().resolve()
                podman_cmd.extend(["-v", f"{h_p}:/mnt/{h_p.name}:Z"])

    if args.root:
        podman_cmd.append("--user")
        podman_cmd.append("root")

    podman_cmd.append(image_tag)

    # --- UPDATE LOGIC ---
    if args.update:
        latest_v = get_latest_opencode_version(debug=args.debug)
        if not latest_v:
            print("⚠️ Skipping update: Could not fetch latest version info.")
        else:
            # Run the container through login shell to check the current version
            v_check_cmd = podman_cmd + ["/bin/bash", "--login", "-c", "opencode --version"]
            try:
                current_v_raw = subprocess.run(v_check_cmd, capture_output=True, text=True, check=True).stdout
                current_v = current_v_raw.strip().split()[-1].lstrip("v")
                
                if version_tuple(current_v) >= version_tuple(latest_v):
                    print(f"✅ OpenCode is already up to date (v{current_v}).")
                    return
                else:
                    print(f"🔄 Updating OpenCode: v{current_v} -> v{latest_v}...")
                    update_cmd = podman_cmd + ["/bin/bash", "-c", "curl -fsSL https://opencode.ai/install | bash"]
                    subprocess.run(update_cmd, check=True)
                    print("✨ Update complete! (Note: The update is persistent in your workspace data directory)")
                    return
            except Exception as e:
                print(f"⚠️ Warning: Could not verify versions: {e}. Attempting update anyway.")
                update_cmd = podman_cmd + ["/bin/bash", "-c", "curl -fsSL https://opencode.ai/install | bash"]
                subprocess.run(update_cmd, check=True)
                return

    # If extra arguments are provided, append them to override the default CMD
    if args.cmd_args:
        podman_cmd.extend(args.cmd_args)

    if args.dry_run:
        print(f"\n[DRY RUN] Command:\n{' '.join(podman_cmd)}\n")
    else:
        print(f"🚀 Sandbox Active | Project: {work_dir.name} ({ws_hash})")
        if is_first_run:
            print("💡 First run for this workspace: OpenCode may perform a one-time database migration. Please wait...")
        if args.debug:
            print(f"DEBUG: podman_cmd={' '.join(podman_cmd)}")
        subprocess.run(podman_cmd)

if __name__ == "__main__":
    doctor_check()
    main()
